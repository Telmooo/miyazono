---
import Layout from "../layouts/Layout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { getCollection } from "astro:content";
import InkParticles from "@/components/portfolio/InkParticles.astro";
import InkDivider from "@/components/portfolio/InkDivider.astro";
import type { Skill } from "@/schemas/portfolio";
import HankoStamp from "@/components/portfolio/HankoStamp.astro";
import ScrollScene from "@/components/portfolio/ScrollScene.astro";

const projectsCollection = await getCollection("projects");
const skillsCollection = await getCollection("skills");

const totalProjects = projectsCollection.length;
const allTech = new Set(projectsCollection.flatMap((p) => p.data.techStack));

const skillCategories: Record<string, { label: string; icon: string }> = {
  "programming-languages": { label: "Programming Languages", icon: "" },
  "machine-learning": { label: "Machine Learning & Data Science", icon: "" },
  backend: { label: "Backend", icon: "" },
  frontend: { label: "Frontend", icon: "" },
  devops: { label: "DevOps", icon: "" },
  tools: { label: "Tools", icon: "" },
  languages: { label: "Languages", icon: "" },
};

const skillsMap = new Map<string, Skill[]>();

for (const skill of skillsCollection) {
  const skillCategory = skill.data.category;
  const categorySkillList = skillsMap.get(skillCategory) ?? [];
  categorySkillList.push(skill.data);
  skillsMap.set(skillCategory, categorySkillList);
}

// Sort skills within each category by proficiency
for (const [skillCategory, skills] of skillsMap) {
  skillsMap.set(
    skillCategory,
    skills.sort((a, b) => b.proficiency - a.proficiency),
  );
}

const featuredProjects = projectsCollection.filter(
  (project) => project.data.featured,
);
const otherProjects = projectsCollection.filter(
  (project) => !project.data.featured,
);
---

<Layout
  title="Portfolio | Telmo Baptista"
  description="Projects, Skills, and Résumé"
>
  <ThemeToggle />
  <InkParticles />

  <main
    class="washi-bg relative z-(--z-content) min-h-screen pb-24"
    id="main-content"
  >
    <header class="scroll-fade mx-auto my-0 max-w-5xl px-8 pt-12 pb-0">
      <a
        href="/"
        class="inline-block text-sm text-(--color-text-secondary) no-underline transition-colors duration-200 hover:text-(--portal-portfolio)"
        aria-label="Return to main hub"
      >
        ← Back to Hub
      </a>
      <div class="mt-6 flex flex-col items-center gap-2">
        <h1
          class="font-(--font-serif) tracking-widest text-(--color-text-primary) text-(--font-size-5xl)"
        >
          Portfolio
        </h1>
        <span
          class="font-(--font-serif) font-normal text-(--color-text-secondary) text-(--font-size-2xl)"
          lang="ja">ポートフォリオ</span
        >
        <p class="mt-2 text-lg text-(--color-text-light)">
          Projects • Skills • Résumé
        </p>
      </div>
    </header>

    <section
      class="stat-bar scroll-fade stagger-1 mx-auto my-8 flex max-w-5xl flex-wrap items-center justify-center gap-6 rounded-3xl px-8 py-6 sm:gap-8"
      aria-label="Portfolio statistics"
    >
      <div class="flex flex-col items-center gap-0.5">
        <span class="font-serif text-2xl font-bold text-(--color-text-primary)">
          {totalProjects}
        </span>
        <span
          class="color-(--color-text-light) font-mono text-sm tracking-wider uppercase"
        >
          Projects
        </span>
      </div>
      <span
        class="hidden h-8 w-0.5 bg-(--color-text-light) opacity-20 sm:block"
        aria-hidden></span>
      <div class="flex flex-col items-center gap-0.5">
        <span class="font-serif text-2xl font-bold text-(--color-text-primary)">
          {allTech.size}
        </span>
        <span
          class="color-(--color-text-light) font-mono text-sm tracking-wider uppercase"
        >
          Technologies
        </span>
      </div>
    </section>

    <InkDivider variant={1} />

    <section
      class="scroll-fade stagger-2 mx-auto mt-8 max-w-5xl px-8"
      aria-label="Skills by domain"
    >
      <h2
        class="mb-2 text-center font-serif text-4xl text-(--color-text-primary)"
      >
        Skill Domains
      </h2>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        {
          Object.entries(skillCategories).map(
            ([categoryKey, { label, icon }]) => {
              const skills = skillsMap.get(categoryKey);
              if (!skills || skills.length === 0) return null;
              return (
                <div class="domain-card rounded-lg p-6">
                  <div class="mb-4 flex items-center gap-2">
                    <span
                      class="font-serif text-lg text-(--color-text-light)"
                      aria-hidden
                    >
                      {icon}
                    </span>
                    <span class="font-mono text-xs tracking-wider text-(--color-text-light) uppercase">
                      {label}
                    </span>
                  </div>
                  <div class="flex flex-wrap items-center gap-3" role="list">
                    {skills.map((skill) => (
                      <HankoStamp
                        name={skill.name}
                        proficiency={skill.proficiency}
                      />
                    ))}
                  </div>
                </div>
              );
            },
          )
        }
      </div>
    </section>

    <InkDivider variant={2} />

    {
      featuredProjects.length > 0 && (
        <section
          class="scroll-fade stagger-3 mx-auto mt-8 max-w-5xl px-8"
          aria-label="Featured projects"
        >
          <h2 class="mb-2 text-center font-serif text-3xl text-(--color-text-primary)">
            Featured Projects
          </h2>
          <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
            {featuredProjects.map((project) => (
              <ScrollScene {...project.data} />
            ))}
          </div>
        </section>
      )
    }

    <InkDivider variant={2} />

    {
      otherProjects.length > 0 && (
        <section
          class="scroll-fade stagger-4 mx-auto mt-8 max-w-5xl px-8"
          aria-label="All projects"
        >
          <h2 class="mb-2 text-center font-serif text-3xl text-(--color-text-primary)">
            Projects
          </h2>

          <div class="lg: grid grid-cols-1 grid-cols-3 gap-6 md:grid-cols-2">
            {otherProjects.map((project) => (
              <ScrollScene {...project.data} />
            ))}
          </div>
        </section>
      )
    }
  </main>
</Layout>

<style>
  /* Washi paper texture background */
  .washi-bg {
    background-color: #f7f3eb;
    background-image: url("data:image/svg+xml,%3Csvg width='40' height='40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23d4c9b8' fill-opacity='0.15'%3E%3Ccircle cx='5' cy='8' r='0.5'/%3E%3Ccircle cx='18' cy='3' r='0.3'/%3E%3Ccircle cx='32' cy='12' r='0.4'/%3E%3Ccircle cx='10' cy='22' r='0.3'/%3E%3Ccircle cx='25' cy='28' r='0.5'/%3E%3Ccircle cx='38' cy='35' r='0.3'/%3E%3Ccircle cx='8' cy='36' r='0.4'/%3E%3Ccircle cx='20' cy='18' r='0.3'/%3E%3Cpath d='M2,15 Q8,14 12,16' stroke='%23d4c9b8' stroke-width='0.3' fill='none' stroke-opacity='0.12'/%3E%3Cpath d='M28,20 Q34,19 38,21' stroke='%23d4c9b8' stroke-width='0.3' fill='none' stroke-opacity='0.1'/%3E%3C/g%3E%3C/svg%3E");
  }

  html[data-theme="dark"] .washi-bg {
    background-color: #1a1a2e;
    background-image: url("data:image/svg+xml,%3Csvg width='40' height='40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Ccircle cx='5' cy='8' r='0.5'/%3E%3Ccircle cx='18' cy='3' r='0.3'/%3E%3Ccircle cx='32' cy='12' r='0.4'/%3E%3Ccircle cx='10' cy='22' r='0.3'/%3E%3Ccircle cx='25' cy='28' r='0.5'/%3E%3Ccircle cx='38' cy='35' r='0.3'/%3E%3Ccircle cx='8' cy='36' r='0.4'/%3E%3Ccircle cx='20' cy='18' r='0.3'/%3E%3Cpath d='M2,15 Q8,14 12,16' stroke='%23ffffff' stroke-width='0.3' fill='none' stroke-opacity='0.03'/%3E%3Cpath d='M28,20 Q34,19 38,21' stroke='%23ffffff' stroke-width='0.3' fill='none' stroke-opacity='0.02'/%3E%3C/g%3E%3C/svg%3E");
  }

  .stat-bar {
    background: rgba(42, 42, 42, 0.04);
  }

  .domain-card {
    padding: 1.5rem;
    border-radius: var(--radius-lg);
    background: rgba(247, 243, 235, 0.5);
    border: 1px solid rgba(42, 42, 42, 0.06);
  }

  html[data-theme="dark"] .domain-card {
    background: rgba(26, 26, 46, 0.4);
    border-color: rgba(255, 255, 255, 0.05);
  }

  .domain-card {
    background: rgba(247, 243, 235, 0.5);
    border: 1px solid rgba(42, 42, 42, 0.06);
  }

  html[data-theme="dark"] .domain-card {
    background: rgba(26, 26, 46, 0.4);
    border-color: rgba(255, 255, 255, 0.05);
  }

  .page-content {
    min-height: 100vh;
    padding: var(--spacing-3xl) var(--spacing-md);
    background: var(--color-bg-primary);
  }

  .page-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--spacing-lg);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-base);
    font-size: var(--font-size-sm);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .page-title {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-md);
  }

  .title-en {
    font-size: var(--font-size-5xl);
    font-family: var(--font-serif);
    color: var(--color-text-primary);
    letter-spacing: 0.05em;
  }

  .title-jp {
    font-size: var(--font-size-2xl);
    font-family: var(--font-serif);
    color: var(--color-text-secondary);
    font-weight: 400;
  }

  .page-subtitle {
    color: var(--color-text-light);
    font-size: var(--font-size-lg);
  }

  .content-section {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--spacing-2xl);
    background: var(--color-bg-secondary);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .content-section h2 {
    color: var(--portal-portfolio);
    margin-bottom: var(--spacing-lg);
  }

  .content-section ul {
    list-style-position: inside;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  @media (max-width: 768px) {
    .page-content {
      padding: var(--spacing-2xl) var(--spacing-md);
    }

    .title-en {
      font-size: var(--font-size-4xl);
    }

    .title-jp {
      font-size: var(--font-size-xl);
    }

    .content-section {
      padding: var(--spacing-lg);
    }
  }
</style>
