---
interface Props {
  variant?: 1 | 2 | 3;
}

const { variant = 1 } = Astro.props;
---

<div class="scroll-unfurl mx-auto my-12 max-w-md px-4">
  {
    variant === 1 && (
      <svg
        viewBox="0 0 400 20"
        class="ink-stroke w-full"
        aria-hidden="true"
        preserveAspectRatio="none"
      >
        <path
          d="M0,10 C30,4 60,16 100,8 C140,0 160,18 200,10 C240,2 280,16 320,8 C360,0 380,14 400,10"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
    )
  }
  {
    variant === 2 && (
      <svg
        viewBox="0 0 400 20"
        class="ink-stroke w-full"
        aria-hidden="true"
        preserveAspectRatio="none"
      >
        <path
          d="M0,12 C50,6 80,14 120,10 C160,6 200,14 240,8 C280,2 340,16 400,10"
          fill="none"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path
          d="M60,14 C80,10 100,16 120,12"
          fill="none"
          stroke="currentColor"
          stroke-width="1"
          stroke-linecap="round"
          opacity="0.4"
        />
      </svg>
    )
  }
  {
    variant === 3 && (
      <svg
        viewBox="0 0 400 24"
        class="ink-stroke w-full"
        aria-hidden="true"
        preserveAspectRatio="none"
      >
        <path
          d="M0,14 C20,8 60,18 100,12 C130,8 170,16 200,10 C230,4 270,18 310,12 C350,6 380,16 400,12"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <circle cx="200" cy="10" r="2" fill="currentColor" opacity="0.3" />
      </svg>
    )
  }
</div>

<style>
  .ink-stroke {
    color: #2a2a2a;
    opacity: 0.3;
  }

  html[data-theme="dark"] .ink-stroke {
    color: #8a8a8a;
    opacity: 0.25;
  }
</style>
